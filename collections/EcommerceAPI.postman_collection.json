          "name": "01_Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Check Status Code is 200\r",
                  "pm.test(\"Login - Status code is 200\", function () {\r",
                  "    pm.expect(pm.response.code).to.equal(200);\r",
                  "});\r",
                  "\r",
                  "// Test 2: Check Response Time\r",
                  "pm.test(\"Login - Response time is less than 2000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "// Test 3: Check Token Exists\r",
                  "pm.test(\"Login - Response has access token\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.accessToken).to.exist;\r",
                  "});\r",
                  "\r",
                  "// Test 4: Check Username is Correct\r",
                  "pm.test(\"Login - Username is correct\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.username).to.eql(\"emilys\");\r",
                  "});\r",
                  "\r",
                  "// Save Token for Future Requests\r",
                  "var jsonData = pm.response.json();\r",
                  "pm.environment.set(\"authToken\", jsonData.accessToken);\r",
                  "console.log(\"✅ Login Successful!\");\r",
                  "console.log(\"Token Saved: \" + jsonData.accessToken);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
